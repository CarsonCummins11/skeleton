# Development stage
FROM oven/bun:1

WORKDIR /app

# Copy package files
COPY frontend/package*.json ./
COPY frontend/bun.lockb ./

# Install dependencies
RUN bun install

# Copy source code
COPY frontend/ ./

# Expose port 5173 (Vite default dev port)
EXPOSE 5173

# Start development server
CMD ["bun", "run", "dev", "--host", "0.0.0.0"] 